#include "kernel_operator.h"
#include "topselection_tiling.h"

class KernelTopSelectionTopP {
public:
    __aicore__ inline void Init(GM_ADDR blockScores, GM_ADDR cuBlockSeqlens,
                                GM_ADDR blockMask, GM_ADDR tiling)
    {
        tiling_ = reinterpret_cast<__gm__ TopSelectionTopPTilingData*>(tiling);
        blockScoresGm_.SetGlobalBuffer(reinterpret_cast<__gm__ float*>(blockScores));
        cuBlockSeqlensGm_.SetGlobalBuffer(reinterpret_cast<__gm__ int32_t*>(cuBlockSeqlens));
        blockMaskGm_.SetGlobalBuffer(reinterpret_cast<__gm__ uint8_t*>(blockMask));
    }

    __aicore__ inline void Process()
    {
        uint32_t req = AscendC::GetBlockIdx();
        if (req >= tiling_->batch) {
            return;
        }

        int32_t blockStart = cuBlockSeqlensGm_.GetValue(req);
        int32_t blockEnd = cuBlockSeqlensGm_.GetValue(req + 1);
        int32_t blockLen = blockEnd - blockStart;
        if (blockLen <= 0) {
            return;
        }

        float scoreSum = 0.0f;
        for (int32_t i = 0; i < blockLen; ++i) {
            float score = blockScoresGm_.GetValue(blockStart + i);
            if (score > 0.0f) {
                scoreSum += score;
            }
        }

        if (scoreSum <= 0.0f) {
            for (int32_t i = 0; i < blockLen; ++i) {
                blockMaskGm_.SetValue(blockStart + i, static_cast<uint8_t>(1));
            }
            return;
        }

        for (int32_t i = 0; i < blockLen; ++i) {
            blockMaskGm_.SetValue(blockStart + i, static_cast<uint8_t>(0));
        }

        float cumulative = 0.0f;
        int32_t kept = 0;
        for (int32_t rank = 0; rank < blockLen; ++rank) {
            float bestScore = -1.0f;
            int32_t bestIndex = -1;
            for (int32_t i = 0; i < blockLen; ++i) {
                uint8_t alreadyKept = blockMaskGm_.GetValue(blockStart + i);
                float score = blockScoresGm_.GetValue(blockStart + i);
                float normalized = score > 0.0f ? score / scoreSum : 0.0f;
                if (alreadyKept == 0 && normalized > bestScore) {
                    bestScore = normalized;
                    bestIndex = i;
                }
            }

            if (bestIndex < 0) {
                break;
            }

            bool keep = (cumulative <= tiling_->p) || (kept == 0);
            if (!keep) {
                break;
            }

            blockMaskGm_.SetValue(blockStart + bestIndex, static_cast<uint8_t>(1));
            cumulative += bestScore;
            kept += 1;
        }
    }

private:
    __gm__ TopSelectionTopPTilingData* tiling_;
    AscendC::GlobalTensor<float> blockScoresGm_;
    AscendC::GlobalTensor<int32_t> cuBlockSeqlensGm_;
    AscendC::GlobalTensor<uint8_t> blockMaskGm_;
};

extern "C" __global__ __vector__ void topselection_top_p_kernel(
    GM_ADDR blockScores, GM_ADDR cuBlockSeqlens, GM_ADDR blockMask, GM_ADDR tiling)
{
    KernelTopSelectionTopP op;
    op.Init(blockScores, cuBlockSeqlens, blockMask, tiling);
    op.Process();
}

