#include "kernel_operator.h"
#include "topselection_tiling.h"

class KernelTopSelectionExpandMask {
public:
    __aicore__ inline void Init(GM_ADDR blockMask, GM_ADDR cuSeqlens,
                                GM_ADDR cuBlockSeqlens, GM_ADDR tokenMask,
                                GM_ADDR newSeqLens, GM_ADDR tiling)
    {
        tiling_ = reinterpret_cast<__gm__ TopSelectionExpandMaskTilingData*>(tiling);
        blockMaskGm_.SetGlobalBuffer(reinterpret_cast<__gm__ uint8_t*>(blockMask));
        cuSeqlensGm_.SetGlobalBuffer(reinterpret_cast<__gm__ int32_t*>(cuSeqlens));
        cuBlockSeqlensGm_.SetGlobalBuffer(reinterpret_cast<__gm__ int32_t*>(cuBlockSeqlens));
        tokenMaskGm_.SetGlobalBuffer(reinterpret_cast<__gm__ uint8_t*>(tokenMask));
        newSeqLensGm_.SetGlobalBuffer(reinterpret_cast<__gm__ int32_t*>(newSeqLens));
    }

    __aicore__ inline void Process()
    {
        uint32_t req = AscendC::GetBlockIdx();
        if (req >= tiling_->batch) {
            return;
        }

        int32_t tokenStart = cuSeqlensGm_.GetValue(req);
        int32_t tokenEnd = cuSeqlensGm_.GetValue(req + 1);
        int32_t seqLen = tokenEnd - tokenStart;
        int32_t blockStart = cuBlockSeqlensGm_.GetValue(req);
        int32_t kept = 0;

        for (int32_t offset = 0; offset < seqLen; ++offset) {
            int32_t blockOffset = offset / static_cast<int32_t>(tiling_->blockSize);
            uint8_t keep = blockMaskGm_.GetValue(blockStart + blockOffset);

            if (offset < static_cast<int32_t>(tiling_->attentionSink)) {
                keep = 1;
            }
            if (offset >= seqLen - static_cast<int32_t>(tiling_->lastQ)) {
                keep = 1;
            }

            tokenMaskGm_.SetValue(tokenStart + offset, keep);
            kept += static_cast<int32_t>(keep != 0);
        }

        newSeqLensGm_.SetValue(req, kept);
    }

private:
    __gm__ TopSelectionExpandMaskTilingData* tiling_;
    AscendC::GlobalTensor<uint8_t> blockMaskGm_;
    AscendC::GlobalTensor<int32_t> cuSeqlensGm_;
    AscendC::GlobalTensor<int32_t> cuBlockSeqlensGm_;
    AscendC::GlobalTensor<uint8_t> tokenMaskGm_;
    AscendC::GlobalTensor<int32_t> newSeqLensGm_;
};

extern "C" __global__ __vector__ void topselection_expand_mask_kernel(
    GM_ADDR blockMask, GM_ADDR cuSeqlens, GM_ADDR cuBlockSeqlens,
    GM_ADDR tokenMask, GM_ADDR newSeqLens, GM_ADDR tiling)
{
    KernelTopSelectionExpandMask op;
    op.Init(blockMask, cuSeqlens, cuBlockSeqlens, tokenMask, newSeqLens, tiling);
    op.Process();
}

