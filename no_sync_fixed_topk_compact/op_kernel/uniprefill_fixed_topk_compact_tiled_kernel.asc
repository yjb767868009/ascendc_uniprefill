#include "kernel_operator.h"
#include "no_sync_tiling.h"

class KernelUniPrefillFixedTopKTiledSelect {
public:
    __aicore__ inline void Init(GM_ADDR blockScores, GM_ADDR cuSeqlens,
                                GM_ADDR cuBlockSeqlens, GM_ADDR keptBlockCuSeqlens,
                                GM_ADDR keepMiddleBlocks, GM_ADDR keptBlockMask,
                                GM_ADDR keptBlockIndices, GM_ADDR tiling)
    {
        tiling_ = reinterpret_cast<__gm__ UniPrefillFixedTopKTiledSelectTilingData*>(tiling);
        blockScoresGm_.SetGlobalBuffer(reinterpret_cast<__gm__ float*>(blockScores));
        cuSeqlensGm_.SetGlobalBuffer(reinterpret_cast<__gm__ int32_t*>(cuSeqlens));
        cuBlockSeqlensGm_.SetGlobalBuffer(reinterpret_cast<__gm__ int32_t*>(cuBlockSeqlens));
        keptBlockCuSeqlensGm_.SetGlobalBuffer(reinterpret_cast<__gm__ int32_t*>(keptBlockCuSeqlens));
        keepMiddleBlocksGm_.SetGlobalBuffer(reinterpret_cast<__gm__ int32_t*>(keepMiddleBlocks));
        keptBlockMaskGm_.SetGlobalBuffer(reinterpret_cast<__gm__ uint8_t*>(keptBlockMask));
        keptBlockIndicesGm_.SetGlobalBuffer(reinterpret_cast<__gm__ int32_t*>(keptBlockIndices));
    }

    __aicore__ inline bool FindRequest(int32_t globalBlock, int32_t &req,
                                       int32_t &blockStart, int32_t &blockEnd) const
    {
        for (uint32_t r = 0; r < tiling_->batch; ++r) {
            int32_t start = cuBlockSeqlensGm_.GetValue(r);
            int32_t end = cuBlockSeqlensGm_.GetValue(r + 1);
            if (globalBlock >= start && globalBlock < end) {
                req = static_cast<int32_t>(r);
                blockStart = start;
                blockEnd = end;
                return true;
            }
        }
        return false;
    }

    __aicore__ inline bool IsForcedKeep(int32_t blockOffset, int32_t seqLen) const
    {
        int32_t blockSize = static_cast<int32_t>(tiling_->blockSize);
        int32_t sinkTokens = static_cast<int32_t>(tiling_->attentionSink);
        int32_t lastQ = static_cast<int32_t>(tiling_->lastQ);
        int32_t blockStartToken = blockOffset * blockSize;
        int32_t blockEndToken = blockStartToken + blockSize;
        return (blockStartToken < sinkTokens) || (blockEndToken > (seqLen - lastQ));
    }

    __aicore__ inline bool IsKeptBlock(int32_t blockStart, int32_t blockLen,
                                       int32_t seqLen, int32_t keepMiddle,
                                       int32_t blockOffset) const
    {
        if (IsForcedKeep(blockOffset, seqLen)) {
            return true;
        }
        if (keepMiddle <= 0) {
            return false;
        }
        float score = blockScoresGm_.GetValue(blockStart + blockOffset);
        int32_t rank = 0;
        for (int32_t i = 0; i < blockLen; ++i) {
            if (i == blockOffset || IsForcedKeep(i, seqLen)) {
                continue;
            }
            float other = blockScoresGm_.GetValue(blockStart + i);
            if ((other > score) || (other == score && i < blockOffset)) {
                rank += 1;
            }
        }
        return rank < keepMiddle;
    }

    __aicore__ inline int32_t KeptOrdinalBefore(int32_t blockStart, int32_t blockLen,
                                                int32_t seqLen, int32_t keepMiddle,
                                                int32_t blockOffset) const
    {
        int32_t ordinal = 0;
        for (int32_t i = 0; i < blockOffset; ++i) {
            if (IsKeptBlock(blockStart, blockLen, seqLen, keepMiddle, i)) {
                ordinal += 1;
            }
        }
        return ordinal;
    }

    __aicore__ inline void Process()
    {
        int32_t globalBlock = static_cast<int32_t>(AscendC::GetBlockIdx());
        int32_t req = 0;
        int32_t blockStart = 0;
        int32_t blockEnd = 0;
        if (!FindRequest(globalBlock, req, blockStart, blockEnd)) {
            return;
        }

        int32_t tokenStart = cuSeqlensGm_.GetValue(req);
        int32_t tokenEnd = cuSeqlensGm_.GetValue(req + 1);
        int32_t seqLen = tokenEnd - tokenStart;
        int32_t blockLen = blockEnd - blockStart;
        int32_t blockOffset = globalBlock - blockStart;
        int32_t keepMiddle = keepMiddleBlocksGm_.GetValue(req);
        bool keep = IsKeptBlock(blockStart, blockLen, seqLen, keepMiddle, blockOffset);
        if (keep) {
            int32_t ordinal = KeptOrdinalBefore(blockStart, blockLen, seqLen, keepMiddle, blockOffset);
            int32_t keptStart = keptBlockCuSeqlensGm_.GetValue(req);
            keptBlockIndicesGm_.SetValue(keptStart + ordinal, blockOffset);
        }

        // Keep this as the final side effect in the select kernel as well.
        // Remote validation showed bisheng may eliminate non-final mask stores.
        keptBlockMaskGm_.SetValue(globalBlock, keep ? 1 : 0);
    }

private:
    __gm__ UniPrefillFixedTopKTiledSelectTilingData* tiling_;
    AscendC::GlobalTensor<float> blockScoresGm_;
    AscendC::GlobalTensor<int32_t> cuSeqlensGm_;
    AscendC::GlobalTensor<int32_t> cuBlockSeqlensGm_;
    AscendC::GlobalTensor<int32_t> keptBlockCuSeqlensGm_;
    AscendC::GlobalTensor<int32_t> keepMiddleBlocksGm_;
    AscendC::GlobalTensor<uint8_t> keptBlockMaskGm_;
    AscendC::GlobalTensor<int32_t> keptBlockIndicesGm_;
};

class KernelUniPrefillFixedTopKTiledCopy {
public:
    __aicore__ inline void Init(GM_ADDR hiddenStates, GM_ADDR residual, GM_ADDR positions,
                                GM_ADDR slotMapping, GM_ADDR cuSeqlens,
                                GM_ADDR keptBlockCuSeqlens, GM_ADDR realCuSeqlens,
                                GM_ADDR keptBlockIndices, GM_ADDR hiddenOut,
                                GM_ADDR residualOut, GM_ADDR positionsOut,
                                GM_ADDR slotMappingOut, GM_ADDR tiling)
    {
        tiling_ = reinterpret_cast<__gm__ UniPrefillFixedTopKTiledCopyTilingData*>(tiling);
        hiddenStatesGm_.SetGlobalBuffer(reinterpret_cast<__gm__ float*>(hiddenStates));
        residualGm_.SetGlobalBuffer(reinterpret_cast<__gm__ float*>(residual));
        positionsGm_.SetGlobalBuffer(reinterpret_cast<__gm__ int64_t*>(positions));
        slotMappingGm_.SetGlobalBuffer(reinterpret_cast<__gm__ int32_t*>(slotMapping));
        cuSeqlensGm_.SetGlobalBuffer(reinterpret_cast<__gm__ int32_t*>(cuSeqlens));
        keptBlockCuSeqlensGm_.SetGlobalBuffer(reinterpret_cast<__gm__ int32_t*>(keptBlockCuSeqlens));
        realCuSeqlensGm_.SetGlobalBuffer(reinterpret_cast<__gm__ int32_t*>(realCuSeqlens));
        keptBlockIndicesGm_.SetGlobalBuffer(reinterpret_cast<__gm__ int32_t*>(keptBlockIndices));
        hiddenOutGm_.SetGlobalBuffer(reinterpret_cast<__gm__ float*>(hiddenOut));
        residualOutGm_.SetGlobalBuffer(reinterpret_cast<__gm__ float*>(residualOut));
        positionsOutGm_.SetGlobalBuffer(reinterpret_cast<__gm__ int64_t*>(positionsOut));
        slotMappingOutGm_.SetGlobalBuffer(reinterpret_cast<__gm__ int32_t*>(slotMappingOut));
    }

    __aicore__ inline bool FindRequest(int32_t keptGlobal, int32_t &req,
                                       int32_t &keptStart, int32_t &keptEnd) const
    {
        for (uint32_t r = 0; r < tiling_->batch; ++r) {
            int32_t start = keptBlockCuSeqlensGm_.GetValue(r);
            int32_t end = keptBlockCuSeqlensGm_.GetValue(r + 1);
            if (keptGlobal >= start && keptGlobal < end) {
                req = static_cast<int32_t>(r);
                keptStart = start;
                keptEnd = end;
                return true;
            }
        }
        return false;
    }

    __aicore__ inline int32_t RealTokenLen(int32_t blockOffset, int32_t seqLen) const
    {
        int32_t blockSize = static_cast<int32_t>(tiling_->blockSize);
        int32_t begin = blockOffset * blockSize;
        int32_t end = begin + blockSize;
        if (end > seqLen) {
            end = seqLen;
        }
        int32_t len = end - begin;
        return len > 0 ? len : 0;
    }

    __aicore__ inline void Process()
    {
        uint32_t pid = AscendC::GetBlockIdx();
        uint32_t hiddenTileCount = tiling_->hiddenTileCount;
        int32_t keptGlobal = static_cast<int32_t>(pid / hiddenTileCount);
        int32_t hiddenTileId = static_cast<int32_t>(pid % hiddenTileCount);

        int32_t req = 0;
        int32_t keptStart = 0;
        int32_t keptEnd = 0;
        if (!FindRequest(keptGlobal, req, keptStart, keptEnd)) {
            return;
        }

        int32_t tokenStart = cuSeqlensGm_.GetValue(req);
        int32_t tokenEnd = cuSeqlensGm_.GetValue(req + 1);
        int32_t seqLen = tokenEnd - tokenStart;
        int32_t localKeptOrdinal = keptGlobal - keptStart;
        int32_t blockOffset = keptBlockIndicesGm_.GetValue(keptGlobal);
        int32_t realLen = RealTokenLen(blockOffset, seqLen);
        if (realLen <= 0) {
            return;
        }

        int32_t blockSize = static_cast<int32_t>(tiling_->blockSize);
        int32_t hiddenSize = static_cast<int32_t>(tiling_->hiddenSize);
        int32_t hiddenTile = static_cast<int32_t>(tiling_->hiddenTile);
        int32_t hStart = hiddenTileId * hiddenTile;
        int32_t hEnd = hStart + hiddenTile;
        if (hEnd > hiddenSize) {
            hEnd = hiddenSize;
        }
        if (hStart >= hiddenSize) {
            return;
        }

        int32_t srcToken = tokenStart + blockOffset * blockSize;
        int32_t dstToken = realCuSeqlensGm_.GetValue(req) + localKeptOrdinal * blockSize;

        for (int32_t t = 0; t < realLen; ++t) {
            int32_t src = srcToken + t;
            int32_t dst = dstToken + t;
            for (int32_t h = hStart; h < hEnd; ++h) {
                int64_t srcIdx = static_cast<int64_t>(src) * hiddenSize + h;
                int64_t dstIdx = static_cast<int64_t>(dst) * hiddenSize + h;
                hiddenOutGm_.SetValue(dstIdx, hiddenStatesGm_.GetValue(srcIdx));
                residualOutGm_.SetValue(dstIdx, residualGm_.GetValue(srcIdx));
            }
            if (hiddenTileId == 0) {
                positionsOutGm_.SetValue(dst, positionsGm_.GetValue(src));
                slotMappingOutGm_.SetValue(dst, slotMappingGm_.GetValue(src));
            }
        }
    }

private:
    __gm__ UniPrefillFixedTopKTiledCopyTilingData* tiling_;
    AscendC::GlobalTensor<float> hiddenStatesGm_;
    AscendC::GlobalTensor<float> residualGm_;
    AscendC::GlobalTensor<int64_t> positionsGm_;
    AscendC::GlobalTensor<int32_t> slotMappingGm_;
    AscendC::GlobalTensor<int32_t> cuSeqlensGm_;
    AscendC::GlobalTensor<int32_t> keptBlockCuSeqlensGm_;
    AscendC::GlobalTensor<int32_t> realCuSeqlensGm_;
    AscendC::GlobalTensor<int32_t> keptBlockIndicesGm_;
    AscendC::GlobalTensor<float> hiddenOutGm_;
    AscendC::GlobalTensor<float> residualOutGm_;
    AscendC::GlobalTensor<int64_t> positionsOutGm_;
    AscendC::GlobalTensor<int32_t> slotMappingOutGm_;
};

__global__ __vector__ void uniprefill_fixed_topk_select_indices_kernel(
    GM_ADDR blockScores, GM_ADDR cuSeqlens, GM_ADDR cuBlockSeqlens,
    GM_ADDR keptBlockCuSeqlens, GM_ADDR keepMiddleBlocks, GM_ADDR keptBlockMask,
    GM_ADDR keptBlockIndices, GM_ADDR tiling)
{
    KernelUniPrefillFixedTopKTiledSelect op;
    op.Init(blockScores, cuSeqlens, cuBlockSeqlens, keptBlockCuSeqlens,
            keepMiddleBlocks, keptBlockMask, keptBlockIndices, tiling);
    op.Process();
}

__global__ __vector__ void uniprefill_fixed_topk_compact_copy_tiled_kernel(
    GM_ADDR hiddenStates, GM_ADDR residual, GM_ADDR positions, GM_ADDR slotMapping,
    GM_ADDR cuSeqlens, GM_ADDR keptBlockCuSeqlens, GM_ADDR realCuSeqlens,
    GM_ADDR keptBlockIndices, GM_ADDR hiddenOut, GM_ADDR residualOut,
    GM_ADDR positionsOut, GM_ADDR slotMappingOut, GM_ADDR tiling)
{
    KernelUniPrefillFixedTopKTiledCopy op;
    op.Init(hiddenStates, residual, positions, slotMapping, cuSeqlens, keptBlockCuSeqlens,
            realCuSeqlens, keptBlockIndices, hiddenOut, residualOut, positionsOut,
            slotMappingOut, tiling);
    op.Process();
}
